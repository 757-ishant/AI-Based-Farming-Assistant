# Copy to .env and fill in real values (never commit .env)

APP_NAME=FarmSaathi
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
PORT=5000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=farming_db

OPENWEATHER_API_KEY=
GEMINI_API_KEY=
NASA_TOKEN=
AGMARKNET_API_KEY=

JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_DAYS=30

AUTH_MODE=local
GOOGLE_CLIENT_ID=

# Optional: model file in backend/models/ (default auto-picks model.h5 then plant_disease_model.h5)
# MODEL_FILE=model.h5
# MODEL_PATH=models/model.h5
